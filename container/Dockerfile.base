# vt-claw Agent Container
# Runs Pi Agent in isolated Linux VM with browser automation

FROM node:22-slim

# 必要的时候可以设置代理，或者使用镜像
# ENV http_proxy="http://192.168.100.197:7078"
# ENV https_proxy="http://192.168.100.197:7078"
RUN apt-get update && apt-get install -y apt-transport-https ca-certificates
COPY debian.sources /etc/apt/sources.list.d/debian.sources
# ENV http_proxy=""
# ENV https_proxy=""


# Install system dependencies for Chromium
RUN apt-get update && apt-get install -y \
    chromium \
    fonts-liberation \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    libgbm1 \
    libnss3 \
    libatk-bridge2.0-0 \
    libgtk-3-0 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libasound2 \
    libpangocairo-1.0-0 \
    libcups2 \
    libdrm2 \
    libxshmfence1 \
    curl \
    git \
    fd-find \
    ripgrep \
    && rm -rf /var/lib/apt/lists/*

# Create the symbolic link
RUN ln -s /bin/fd-find /bin/fd

# Set Chromium path for agent-browser
ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Install agent-browser and claude-code globally

# 必要的时候也可以关闭代理 
ENV http_proxy=""
ENV https_proxy=""
RUN npm install -g agent-browser @mariozechner/pi-coding-agent@0.60.0